# Production note:
# - explicit private CIDRs only; no broad docker-subnet defaults
PROVIDER_HTTP_ADDR=:8080
PROVIDER_DATA_PATH=/var/lib/audistro-provider
PROVIDER_STORAGE_MODE=filesystem
PROVIDER_CATALOG_BASE_URL=https://catalog.example.com
PROVIDER_PUBLIC_BASE_URL=https://provider-us-1.example.com
PROVIDER_ALLOW_INSECURE_PUBLIC_URL=false
PROVIDER_TRANSPORT=https
PROVIDER_INTERNAL_ENABLE=true
PROVIDER_INTERNAL_ALLOWED_CIDRS=
PROVIDER_ORIGIN_AUTH_MODE=none
PROVIDER_ORIGIN_HMAC_SECRET_PATH=/run/secrets/origin_hmac_secret
PROVIDER_ENABLE_CORS=false
PROVIDER_CORS_ALLOWED_ORIGINS=
PROVIDER_REGION=us-east
PROVIDER_ANNOUNCE_PRIORITY=5
