AUDICATALOG_HTTP_ADDR=:8080
AUDICATALOG_DB_PATH=/var/lib/audistro-catalog/audistro-catalog.db
CATALOG_ENV=prod
CATALOG_ADMIN_TOKEN=
CATALOG_ALLOW_INSECURE_TRANSPORT=false
CATALOG_STORAGE_PATH=/var/lib/audistro-catalog
CATALOG_PROVIDER_PUBLIC_BASE_URL=https://provider-eu-1.example.com
CATALOG_PROVIDER_INTERNAL_BASE_URL=http://audistro-provider_eu_1:8080
CATALOG_PROVIDER_TARGETS=eu_1|https://provider-eu-1.example.com|http://audistro-provider_eu_1:8080|/mnt/providers/eu_1,eu_2|https://provider-eu-2.example.com|http://audistro-provider_eu_2:8080|/mnt/providers/eu_2
CATALOG_FAP_INTERNAL_BASE_URL=http://audistro-fap:8080
FAP_PUBLIC_BASE_URL=https://api.example.com/fap
FAP_ADMIN_TOKEN=
