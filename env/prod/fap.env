FAP_HTTP_ADDR=:8080
FAP_DB_PATH=/var/lib/fap/fap.db
FAP_LNBITS_BASE_URL=https://lnbits.example.com
FAP_LNBITS_INVOICE_API_KEY=
FAP_LNBITS_READONLY_API_KEY=
FAP_ISSUER_PRIVKEY_HEX=
FAP_MASTER_KEY_HEX=
FAP_WEBHOOK_SECRET=
FAP_TOKEN_SECRET_PATH=/run/secrets/fap_token_secret
FAP_ADMIN_TOKEN=
FAP_INTERNAL_ALLOWED_CIDRS=
FAP_DEV_MODE=false
FAP_EXPOSE_BOLT11_IN_LIST=false
FAP_DEVICE_COOKIE_SECURE=true
FAP_ENABLE_CORS=false
FAP_CORS_ALLOWED_ORIGINS=
FAP_CORS_ALLOW_CREDENTIALS=false
